@page "/recipe/{Id:int}"
@using RecipeApp.Models
@using RecipeApp.Services
@using System.Text.Json
@using System.Security.Claims
@inject IRecipeService RecipeService
@inject IBringService BringService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@(Recipe?.Title ?? "Rezept Details")</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    @if (!string.IsNullOrEmpty(BringMessage))
    {
        <div class="mb-4 p-4 rounded-md @(IsBringSuccess ? "bg-green-50 text-green-800" : "bg-red-50 text-red-800")">
            @BringMessage
        </div>
    }
    @if (IsLoading)
    {
        <div class="flex justify-center mt-8">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
        </div>
    }
    else if (Recipe == null)
    {
        <div class="text-center py-12 bg-white rounded-lg shadow">
            <h3 class="mt-2 text-sm font-medium text-gray-900">Rezept nicht gefunden</h3>
            <p class="mt-1 text-sm text-gray-500">Das angeforderte Rezept existiert nicht oder wurde gelöscht.</p>
            <div class="mt-6">
                <a href="/" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700">
                    Zurück zur Übersicht
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="bg-white shadow overflow-hidden sm:rounded-lg mb-8">
            @if (!string.IsNullOrEmpty(Recipe.ImageUrl))
            {
                <div class="w-full h-64 md:h-96 relative">
                    <img src="@Recipe.ImageUrl" alt="@Recipe.Title" class="w-full h-full object-cover" />
                    <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-black opacity-60 h-24"></div>
                    <div class="absolute bottom-4 left-4 md:bottom-8 md:left-8">
                        <h1 class="text-3xl font-bold text-white">@Recipe.Title</h1>
                    </div>
                </div>
            }
            <div class="px-4 py-5 sm:px-6 flex justify-between items-center flex-wrap gap-4">
                <div>
                    @if (string.IsNullOrEmpty(Recipe.ImageUrl))
                    {
                        <h1 class="text-3xl font-bold text-gray-900">@Recipe.Title</h1>
                    }
                    <p class="mt-1 max-w-2xl text-sm text-gray-500">
                        Hinzugefügt am @Recipe.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")
                    </p>
                    @if (Recipe.Ratings != null && Recipe.Ratings.Any())
                    {
                        <div class="mt-2 flex items-center text-sm text-yellow-500">
                            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                            <span class="ml-1 text-gray-600">@Math.Round(Recipe.Ratings.Average(r => r.Score), 1) (@Recipe.Ratings.Count)</span>
                        </div>
                    }
                    else
                    {
                        <div class="mt-2 text-sm text-gray-400">Keine Bewertungen</div>
                    }
                </div>

                <div class="flex space-x-3">
                    <button @onclick="ShareRecipe" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                        @if (isCopied)
                        {
                            <span class="text-green-600">Link kopiert!</span>
                        }
                        else
                        {
                            <span>Teilen</span>
                        }
                    </button>
                    @if (IsOwnerOrAdmin)
                    {
                        <a href="/recipe/edit/@Recipe.Id" class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                            Bearbeiten
                        </a>
                        <button @onclick="DeleteRecipe" class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500">
                            Löschen
                        </button>
                    }
                </div>
            </div>

            <div class="border-t border-gray-200 px-4 py-5 sm:p-0">
                <dl class="sm:divide-y sm:divide-gray-200">
                    <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">Beschreibung</dt>
                        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">@Recipe.Description</dd>
                    </div>

                    <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                        <dt class="text-sm font-medium text-gray-500">Details</dt>
                        <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2">
                            <div class="flex flex-wrap gap-4">
                                <div class="flex items-center">
                                    <span class="font-semibold mr-2">Schwierigkeit:</span> @Recipe.Difficulty.ToString()
                                </div>
                                <div class="flex items-center">
                                    <span class="font-semibold mr-2">Kochzeit:</span> @Recipe.CookingTimeMinutes Minuten
                                </div>
                                <div class="flex items-center">
                                    <span class="font-semibold mr-2">Portionen:</span> @Recipe.Servings
                                </div>
                            </div>
                        </dd>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Recipe.Tags))
                    {
                        <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                            <dt class="text-sm font-medium text-gray-500">Tags</dt>
                            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 flex flex-wrap gap-2">
                                @foreach (var tag in Recipe.Tags.Split(',').Select(t => t.Trim()))
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-800">
                                        @tag
                                    </span>
                                }
                            </dd>
                        </div>
                    }

                    @if (Recipe.Categories != null && Recipe.Categories.Any())
                    {
                        <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                            <dt class="text-sm font-medium text-gray-500">Kategorien</dt>
                            <dd class="mt-1 text-sm text-gray-900 sm:mt-0 sm:col-span-2 flex flex-wrap gap-2">
                                @foreach (var cat in Recipe.Categories)
                                {
                                    <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-gray-100 text-gray-800 border border-gray-200 shadow-sm">
                                        <span class="mr-1">@cat.Icon</span> @cat.Name
                                    </span>
                                }
                            </dd>
                        </div>
                    }
                </dl>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="md:col-span-1">
                <div class="bg-white shadow sm:rounded-lg">
                    <div class="px-4 py-5 sm:p-6">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-lg leading-6 font-medium text-gray-900">Zutaten</h3>
                            <button @onclick="AddIngredientsToBring" disabled="@IsAddingToBring" class="inline-flex items-center px-3 py-1.5 border border-transparent text-xs font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 disabled:opacity-50">
                                @if (IsAddingToBring)
                                {
                                    <span>Füge hinzu...</span>
                                }
                                else
                                {
                                    <span>Zutaten auf Einkaufsliste</span>
                                }
                            </button>
                        </div>
                        <ul class="divide-y divide-gray-200">
                            @foreach (var ingredient in GetIngredients())
                            {
                                <li class="py-3 flex items-center">
                                    <svg class="h-5 w-5 text-indigo-500 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <span class="text-gray-700">@ingredient</span>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <div class="md:col-span-2">
                <div class="bg-white shadow sm:rounded-lg">
                    <div class="px-4 py-5 sm:p-6">
                        <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Zubereitung</h3>
                        <div class="space-y-6">
                            @{ var stepNumber = 1; }
                            @foreach (var step in GetInstructions())
                            {
                                <div class="flex">
                                    <div class="flex-shrink-0 mr-4">
                                        <div class="flex items-center justify-center h-8 w-8 rounded-full bg-indigo-100 text-indigo-800 font-bold">
                                            @stepNumber
                                        </div>
                                    </div>
                                    <div>
                                        <p class="text-gray-700 mt-1">@step</p>
                                    </div>
                                </div>
                                stepNumber++;
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-8 bg-white shadow sm:rounded-lg">
            <div class="px-4 py-5 sm:p-6">
                <h3 class="text-lg leading-6 font-medium text-gray-900 mb-4">Bewertungen & Kommentare</h3>

                @if (currentUserId != null)
                {
                    <div class="mb-8 border-b border-gray-200 pb-8">
                        <h4 class="text-md font-medium text-gray-900 mb-2">Rezept bewerten</h4>
                        <div class="flex items-center space-x-1 mb-4">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var starValue = i;
                                <button @onclick="() => RateRecipe(starValue)" class="focus:outline-none">
                                    <svg class="h-8 w-8 @(UserRating >= starValue ? "text-yellow-400" : "text-gray-300") hover:text-yellow-400 transition-colors" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                    </svg>
                                </button>
                            }
                        </div>

                        <h4 class="text-md font-medium text-gray-900 mb-2">Kommentar schreiben</h4>
                        <div class="mt-1">
                            <textarea @bind="NewCommentText" maxlength="1000" rows="3" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md border p-2" placeholder="Wie hat es dir geschmeckt?"></textarea>
                        </div>
                        <div class="mt-3 flex justify-end">
                            <button @onclick="SubmitComment" disabled="@string.IsNullOrWhiteSpace(NewCommentText)" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 disabled:opacity-50">
                                Kommentieren
                            </button>
                        </div>
                    </div>
                }
                else
                {
                    <div class="mb-8 p-4 bg-gray-50 rounded-md text-sm text-gray-700">
                        Bitte <a href="/Account/Login" class="text-indigo-600 hover:text-indigo-500 font-medium">melde dich an</a>, um dieses Rezept zu bewerten oder zu kommentieren.
                    </div>
                }

                <div>
                    @if (Recipe.Comments != null && Recipe.Comments.Any())
                    {
                        <ul class="space-y-6">
                            @foreach (var comment in Recipe.Comments.OrderByDescending(c => c.CreatedAt))
                            {
                                <li class="bg-gray-50 px-4 py-4 sm:px-6 rounded-lg">
                                    <div class="flex space-x-3">
                                        <div class="flex-shrink-0">
                                            <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-800 font-bold">
                                                @((comment.User?.UserName ?? "U")[0].ToString().ToUpper())
                                            </div>
                                        </div>
                                        <div class="min-w-0 flex-1">
                                            <p class="text-sm font-medium text-gray-900">
                                                @(comment.User?.UserName ?? "Unbekannter Benutzer")
                                            </p>
                                            <p class="text-sm text-gray-500">
                                                @comment.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                            </p>
                                            <div class="mt-2 text-sm text-gray-700 whitespace-pre-line">
                                                @comment.Text
                                            </div>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-gray-500 text-sm">Noch keine Kommentare vorhanden. Sei der Erste!</p>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Recipe? Recipe;
    private bool IsLoading = true;
    private bool IsAddingToBring = false;
    private string? BringMessage;
    private bool IsBringSuccess = false;

    private bool IsOwnerOrAdmin = false;
    private string? currentUserId;
    private bool isAdmin = false;

    private bool isCopied = false;
    private string NewCommentText = string.Empty;
    private int UserRating = 0;

    protected override async Task OnInitializedAsync()
    {
        Recipe = await RecipeService.GetByIdAsync(Id);

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserId = user.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value;
        isAdmin = user.Identity?.Name == "admin@rezeptbuch.de";

        if (Recipe != null)
        {
            IsOwnerOrAdmin = isAdmin || (currentUserId != null && currentUserId == Recipe.OwnerId);

            if (currentUserId != null && Recipe.Ratings != null)
            {
                var existingRating = Recipe.Ratings.FirstOrDefault(r => r.UserId == currentUserId);
                if (existingRating != null)
                {
                    UserRating = existingRating.Score;
                }
            }
        }

        IsLoading = false;
    }

    private List<string> GetIngredients()
    {
        if (string.IsNullOrEmpty(Recipe?.IngredientsJson) || Recipe.IngredientsJson == "[]")
            return new List<string>();

        try
        {
            return JsonSerializer.Deserialize<List<string>>(Recipe.IngredientsJson) ?? new List<string>();
        }
        catch
        {
            return new List<string>();
        }
    }

    private List<string> GetInstructions()
    {
        if (string.IsNullOrEmpty(Recipe?.InstructionsJson) || Recipe.InstructionsJson == "[]")
            return new List<string>();

        try
        {
            return JsonSerializer.Deserialize<List<string>>(Recipe.InstructionsJson) ?? new List<string>();
        }
        catch
        {
            return new List<string>();
        }
    }

    private async Task DeleteRecipe()
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Möchtest du dieses Rezept wirklich löschen?");
        if (confirmed)
        {
            await RecipeService.DeleteAsync(Id, currentUserId, isAdmin);
            NavigationManager.NavigateTo("/");
        }
    }

    private async Task AddIngredientsToBring()
    {
        if (Recipe == null) return;

        var ingredients = GetIngredients();
        if (!ingredients.Any()) return;

        IsAddingToBring = true;
        BringMessage = null;

        var success = await BringService.AddItemsAsync(ingredients);

        if (success)
        {
            IsBringSuccess = true;
            BringMessage = "Zutaten wurden erfolgreich zur Einkaufsliste hinzugefügt!";
        }
        else
        {
            IsBringSuccess = false;
            BringMessage = "Fehler beim Hinzufügen der Zutaten zur Einkaufsliste. Bitte überprüfe die Konfiguration.";
        }

        IsAddingToBring = false;

        // Hide message after 5 seconds
        _ = Task.Delay(5000).ContinueWith(_ =>
        {
            BringMessage = null;
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task ShareRecipe()
    {
        var url = NavigationManager.Uri;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", url);
        isCopied = true;

        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            isCopied = false;
            InvokeAsync(StateHasChanged);
        });
    }

    private async Task SubmitComment()
    {
        if (string.IsNullOrWhiteSpace(NewCommentText) || currentUserId == null || Recipe == null) return;

        await RecipeService.AddCommentAsync(Recipe.Id, currentUserId, NewCommentText);
        NewCommentText = string.Empty;

        // Reload to show new comment
        Recipe = await RecipeService.GetByIdAsync(Id);
    }

    private async Task RateRecipe(int score)
    {
        if (currentUserId == null || Recipe == null) return;

        UserRating = score;
        await RecipeService.AddOrUpdateRatingAsync(Recipe.Id, currentUserId, score);

        // Reload to show new average rating
        Recipe = await RecipeService.GetByIdAsync(Id);
    }
}
