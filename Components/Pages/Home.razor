@page "/"
@implements IDisposable
@using RecipeApp.Models
@using RecipeApp.Services
@inject IRecipeService RecipeService
@inject NavigationManager NavigationManager

<PageTitle>Rezepte</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="md:flex md:items-center md:justify-between mb-8">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                Alle Rezepte
            </h2>
        </div>
        <div class="mt-4 flex md:mt-0 md:ml-4">
            <a href="/recipe/create" class="ml-3 inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Neues Rezept
            </a>
        </div>
    </div>

    <div class="bg-white shadow px-4 py-5 sm:rounded-lg sm:p-6 mb-8">
        <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
            <div class="sm:col-span-3">
                <label for="search" class="block text-sm font-medium text-gray-700">Suchen</label>
                <div class="mt-1">
                    <input type="text" id="search" @bind="SearchTerm" @bind:event="oninput" @onkeyup="HandleSearch" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border" placeholder="Titel oder Beschreibung...">
                </div>
            </div>

            <div class="sm:col-span-2">
                <label for="filter-difficulty" class="block text-sm font-medium text-gray-700">Schwierigkeit</label>
                <div class="mt-1">
                    <select id="filter-difficulty" @bind="SelectedDifficulty" @bind:after="LoadRecipes" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border">
                        <option value="">Alle</option>
                        @foreach (var difficulty in Enum.GetValues<Difficulty>())
                        {
                            <option value="@difficulty">@difficulty.ToString()</option>
                        }
                    </select>
                </div>
            </div>

            <div class="sm:col-span-1">
                <label for="filter-tag" class="block text-sm font-medium text-gray-700">Tag</label>
                <div class="mt-1">
                    <input type="text" id="filter-tag" @bind="FilterTag" @bind:event="oninput" @onkeyup="HandleSearch" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border" placeholder="z.B. Pasta">
                </div>
            </div>
        </div>
    </div>

    @if (Recipes == null)
    {
        <div class="flex justify-center mt-8">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
        </div>
    }
    else if (!Recipes.Any())
    {
        <div class="text-center py-12 bg-white rounded-lg shadow">
            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
            </svg>
            <h3 class="mt-2 text-sm font-medium text-gray-900">Keine Rezepte gefunden</h3>
            <p class="mt-1 text-sm text-gray-500">Versuche es mit anderen Suchkriterien oder lege ein neues Rezept an.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            @foreach (var recipe in Recipes)
            {
                <div class="bg-white overflow-hidden shadow rounded-lg flex flex-col cursor-pointer transition transform hover:-translate-y-1 hover:shadow-lg" @onclick="() => NavigateToRecipe(recipe.Id)">
                    <div class="flex-shrink-0 h-48 w-full bg-gray-200 relative">
                        @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                        {
                            <img class="h-48 w-full object-cover" src="@recipe.ImageUrl" alt="@recipe.Title">
                        }
                        else
                        {
                            <div class="h-full w-full flex items-center justify-center text-gray-400">
                                <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                            </div>
                        }
                        <div class="absolute top-2 right-2 bg-white px-2 py-1 rounded-md text-xs font-semibold text-gray-700 shadow-sm opacity-90">
                            @recipe.Difficulty.ToString()
                        </div>
                    </div>
                    <div class="px-4 py-5 sm:p-6 flex-1 flex flex-col">
                        <h3 class="text-lg leading-6 font-medium text-gray-900 line-clamp-1 mb-2">@recipe.Title</h3>
                        <p class="text-sm text-gray-500 line-clamp-2 flex-1">@recipe.Description</p>

                        <div class="mt-4 flex items-center justify-between text-sm text-gray-500">
                            <div class="flex items-center">
                                <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                @recipe.CookingTimeMinutes Min
                            </div>
                            <div class="flex items-center">
                                <svg class="flex-shrink-0 mr-1.5 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                                @recipe.Servings Port.
                            </div>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(recipe.Tags))
                    {
                        <div class="px-4 py-3 bg-gray-50 border-t border-gray-200 rounded-b-lg">
                            <div class="flex flex-wrap gap-1">
                                @foreach (var tag in recipe.Tags.Split(',').Select(t => t.Trim()).Take(3))
                                {
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-indigo-100 text-indigo-800">
                                        @tag
                                    </span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Recipe>? Recipes;

    private string SearchTerm { get; set; } = string.Empty;
    private Difficulty? SelectedDifficulty { get; set; }
    private string FilterTag { get; set; } = string.Empty;

    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipes();

        _debounceTimer = new System.Timers.Timer(300);
        _debounceTimer.Elapsed += async (sender, e) =>
        {
            await InvokeAsync(async () =>
            {
                await LoadRecipes();
                StateHasChanged();
            });
        };
        _debounceTimer.AutoReset = false;
    }

    private void HandleSearch(KeyboardEventArgs e)
    {
        _debounceTimer?.Stop();
        _debounceTimer?.Start();
    }

    private async Task LoadRecipes()
    {
        Recipes = await RecipeService.GetAllAsync(SearchTerm, FilterTag, SelectedDifficulty);
    }

    private void NavigateToRecipe(int id)
    {
        NavigationManager.NavigateTo($"/recipe/{id}");
    }

    public void Dispose()
    {
        _debounceTimer?.Dispose();
    }
}
