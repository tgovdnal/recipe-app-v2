@page "/mealplanner"
@using RecipeApp.Models
@using RecipeApp.Services
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IMealPlanService MealPlanService
@inject IRecipeService RecipeService
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Wochenplan</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="md:flex md:items-center md:justify-between mb-8">
        <div class="flex-1 min-w-0">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:text-3xl sm:truncate">
                Wochenplan
            </h2>
        </div>
        <div class="mt-4 flex md:mt-0 md:ml-4 items-center gap-4">
            <button @onclick="PreviousWeek" class="inline-flex items-center p-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
            </button>
            <span class="text-lg font-medium text-gray-900">
                @CurrentWeekStart.ToString("dd.MM.") - @CurrentWeekStart.AddDays(6).ToString("dd.MM.yyyy")
            </span>
            <button @onclick="NextWeek" class="inline-flex items-center p-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </button>
            <a href="/weekly-shopping-list" class="ml-3 inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700">
                Einkaufsliste
            </a>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="flex justify-center mt-8">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600"></div>
        </div>
    }
    else
    {
        <div class="bg-white shadow rounded-lg overflow-hidden overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider w-32">Mahlzeit</th>
                        @for (int i = 0; i < 7; i++)
                        {
                            var date = CurrentWeekStart.AddDays(i);
                            var isToday = date.Date == DateTime.Today;
                            <th scope="col" class="px-4 py-3 text-center text-xs font-medium text-gray-500 uppercase tracking-wider @(isToday ? "bg-indigo-50 text-indigo-700" : "")">
                                <div>@date.ToString("ddd", new System.Globalization.CultureInfo("de-DE"))</div>
                                <div class="text-sm font-bold @(isToday ? "text-indigo-900" : "text-gray-900")">@date.ToString("dd.MM.")</div>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var mealType in Enum.GetValues<MealType>())
                    {
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900 bg-gray-50">
                                @mealType.ToString()
                            </td>
                            @for (int i = 0; i < 7; i++)
                            {
                                var date = CurrentWeekStart.AddDays(i);
                                var plan = MealPlans.FirstOrDefault(m => m.Date.Date == date.Date && m.MealType == mealType);

                                <td class="px-2 py-2 text-center border-l border-gray-100 min-w-[150px] align-top">
                                    @if (plan != null && plan.Recipe != null)
                                    {
                                        <div class="relative group bg-white border border-gray-200 rounded-md p-2 shadow-sm hover:shadow-md transition-shadow text-left h-full flex flex-col">
                                            <a href="/recipe/@plan.RecipeId" class="text-sm font-medium text-indigo-600 hover:text-indigo-900 line-clamp-2 mb-1">
                                                @plan.Recipe.Title
                                            </a>
                                            <div class="text-xs text-gray-500 flex gap-2 mt-auto">
                                                <span>⏱️ @plan.Recipe.CookingTimeMinutes m</span>
                                                <span>👥 @plan.Recipe.Servings P.</span>
                                            </div>
                                            <button @onclick="() => RemoveRecipe(plan.Id)" class="absolute -top-2 -right-2 bg-red-100 text-red-600 rounded-full p-1 opacity-0 group-hover:opacity-100 hover:bg-red-200 transition-opacity">
                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button @onclick="() => OpenRecipeSelector(date, mealType)" class="w-full h-full min-h-[60px] border-2 border-dashed border-gray-300 rounded-md flex flex-col items-center justify-center text-gray-400 hover:text-indigo-500 hover:border-indigo-500 hover:bg-indigo-50 transition-colors p-2">
                                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                            <span class="text-xs mt-1">Hinzufügen</span>
                                        </button>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (ShowRecipeSelector)
{
    <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity z-40" aria-hidden="true"></div>

    <div class="fixed inset-0 z-50 overflow-y-auto">
        <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
            <div class="relative transform overflow-hidden rounded-lg bg-white px-4 pt-5 pb-4 text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-2xl sm:p-6">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-medium leading-6 text-gray-900">Rezept auswählen</h3>
                    <button @onclick="CloseRecipeSelector" class="text-gray-400 hover:text-gray-500">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>

                <div class="mb-4">
                    <input type="text" @bind="SearchTerm" @bind:event="oninput" @onkeyup="FilterRecipes" class="shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-gray-300 rounded-md p-2 border" placeholder="Rezepte suchen...">
                </div>

                <div class="max-h-96 overflow-y-auto pr-2">
                    @if (FilteredRecipes == null)
                    {
                        <div class="text-center py-4 text-gray-500">Lade Rezepte...</div>
                    }
                    else if (!FilteredRecipes.Any())
                    {
                        <div class="text-center py-4 text-gray-500">Keine Rezepte gefunden.</div>
                    }
                    else
                    {
                        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                            @foreach (var recipe in FilteredRecipes)
                            {
                                <div @onclick="() => SelectRecipe(recipe.Id)" class="cursor-pointer border border-gray-200 rounded-lg p-3 hover:border-indigo-500 hover:shadow-sm transition-all flex items-center gap-3">
                                    @if (!string.IsNullOrEmpty(recipe.ImageUrl))
                                    {
                                        <img src="@recipe.ImageUrl" class="h-12 w-12 rounded-md object-cover" />
                                    }
                                    else
                                    {
                                        <div class="h-12 w-12 rounded-md bg-gray-100 flex items-center justify-center text-gray-400">
                                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                        </div>
                                    }
                                    <div class="flex-1 min-w-0">
                                        <h4 class="text-sm font-medium text-gray-900 truncate">@recipe.Title</h4>
                                        <p class="text-xs text-gray-500 truncate">⏱️ @recipe.CookingTimeMinutes m | 👥 @recipe.Servings P.</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private DateTime CurrentWeekStart;
    private List<MealPlan> MealPlans = new();
    private bool IsLoading = true;
    private string UserId = string.Empty;

    // Modal state
    private bool ShowRecipeSelector = false;
    private DateTime SelectedDate;
    private MealType SelectedMealType;

    // Recipe selection state
    private List<Recipe>? AllRecipes;
    private List<Recipe>? FilteredRecipes;
    private string SearchTerm = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        UserId = authState.User.FindFirst(c => c.Type == ClaimTypes.NameIdentifier)?.Value ?? string.Empty;

        // Set to current week's Monday
        var today = DateTime.Today;
        int diff = (7 + (today.DayOfWeek - DayOfWeek.Monday)) % 7;
        CurrentWeekStart = today.AddDays(-1 * diff).Date;

        await LoadData();
    }

    private async Task LoadData()
    {
        IsLoading = true;
        MealPlans = await MealPlanService.GetMealPlansForWeekAsync(UserId, CurrentWeekStart);
        IsLoading = false;
    }

    private async Task PreviousWeek()
    {
        CurrentWeekStart = CurrentWeekStart.AddDays(-7);
        await LoadData();
    }

    private async Task NextWeek()
    {
        CurrentWeekStart = CurrentWeekStart.AddDays(7);
        await LoadData();
    }

    private async Task OpenRecipeSelector(DateTime date, MealType mealType)
    {
        SelectedDate = date;
        SelectedMealType = mealType;
        ShowRecipeSelector = true;
        SearchTerm = string.Empty;

        if (AllRecipes == null)
        {
            AllRecipes = await RecipeService.GetAllAsync();
        }
        FilteredRecipes = AllRecipes;
    }

    private void CloseRecipeSelector()
    {
        ShowRecipeSelector = false;
    }

    private void FilterRecipes(KeyboardEventArgs e)
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            FilteredRecipes = AllRecipes;
        }
        else
        {
            FilteredRecipes = AllRecipes?.Where(r => r.Title.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                                                     r.Description.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private async Task SelectRecipe(int recipeId)
    {
        await MealPlanService.AssignRecipeToMealAsync(UserId, SelectedDate, SelectedMealType, recipeId);
        CloseRecipeSelector();
        await LoadData();
    }

    private async Task RemoveRecipe(int mealPlanId)
    {
        await MealPlanService.RemoveRecipeFromMealAsync(UserId, mealPlanId);
        await LoadData();
    }
}
