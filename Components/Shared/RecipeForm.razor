@using RecipeApp.Models
@using RecipeApp.Services
@using System.Text.Json
@inject IRecipeService RecipeService

<EditForm Model="Recipe" OnValidSubmit="HandleSubmit" FormName="RecipeForm">
    <DataAnnotationsValidator />

    <div class="space-y-6">
        <div>
            <label for="title" class="block text-sm font-medium text-gray-700">Titel</label>
            <InputText id="title" @bind-Value="Recipe.Title" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" />
            <ValidationMessage For="@(() => Recipe.Title)" class="text-red-500 text-xs mt-1" />
        </div>

        <div>
            <label for="description" class="block text-sm font-medium text-gray-700">Beschreibung</label>
            <InputTextArea id="description" @bind-Value="Recipe.Description" rows="3" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" />
            <ValidationMessage For="@(() => Recipe.Description)" class="text-red-500 text-xs mt-1" />
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label for="difficulty" class="block text-sm font-medium text-gray-700">Schwierigkeit</label>
                <InputSelect id="difficulty" @bind-Value="Recipe.Difficulty" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border">
                    @foreach (var difficulty in Enum.GetValues<Difficulty>())
                    {
                        <option value="@difficulty">@difficulty.ToString()</option>
                    }
                </InputSelect>
            </div>
            <div>
                <label for="cookingTime" class="block text-sm font-medium text-gray-700">Kochzeit (Min)</label>
                <InputNumber id="cookingTime" @bind-Value="Recipe.CookingTimeMinutes" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" />
                <ValidationMessage For="@(() => Recipe.CookingTimeMinutes)" class="text-red-500 text-xs mt-1" />
            </div>
            <div>
                <label for="servings" class="block text-sm font-medium text-gray-700">Portionen</label>
                <InputNumber id="servings" @bind-Value="Recipe.Servings" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" />
                <ValidationMessage For="@(() => Recipe.Servings)" class="text-red-500 text-xs mt-1" />
            </div>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Zutaten (Zeilenweise)</label>
            <textarea @bind="IngredientsText" rows="5" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" placeholder="400g Spaghetti&#13;&#10;150g Guanciale"></textarea>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Zubereitungsschritte (Zeilenweise)</label>
            <textarea @bind="InstructionsText" rows="5" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" placeholder="Nudeln kochen.&#13;&#10;Speck braten."></textarea>
        </div>

        <div>
            <label for="tags" class="block text-sm font-medium text-gray-700">Tags (Komma getrennt)</label>
            <InputText id="tags" @bind-Value="Recipe.Tags" class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm p-2 border" placeholder="Pasta, Italienisch, Schnell" />
        </div>

        <div>
            <label for="image" class="block text-sm font-medium text-gray-700">Bild</label>
            <InputFile id="image" OnChange="HandleImageUpload" class="mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" accept=".jpg,.jpeg,.png,.webp" />
            @if (!string.IsNullOrEmpty(ImageError))
            {
                <p class="text-red-500 text-xs mt-1">@ImageError</p>
            }
            @if (!string.IsNullOrEmpty(Recipe.ImageUrl))
            {
                <div class="mt-2">
                    <img src="@Recipe.ImageUrl" alt="Preview" class="h-32 w-auto object-cover rounded-md" />
                </div>
            }
        </div>

        <div class="flex justify-end gap-3 pt-4 border-t">
            <button type="button" @onclick="OnCancel" class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                Abbrechen
            </button>
            <button type="submit" disabled="@IsSubmitting" class="bg-indigo-600 border border-transparent rounded-md shadow-sm py-2 px-4 inline-flex justify-center text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500">
                @if (IsSubmitting)
                {
                    <span class="mr-2">Speichern...</span>
                }
                else
                {
                    <span>Speichern</span>
                }
            </button>
        </div>
    </div>
</EditForm>

@code {
    [Parameter] public Recipe Recipe { get; set; } = new();
    [Parameter] public EventCallback<Recipe> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private bool IsSubmitting { get; set; }
    private string ImageError { get; set; } = string.Empty;

    private string _ingredientsText = string.Empty;
    private string IngredientsText
    {
        get => _ingredientsText;
        set
        {
            _ingredientsText = value;
            var list = value.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                            .Select(s => s.Trim())
                            .ToList();
            Recipe.IngredientsJson = JsonSerializer.Serialize(list);
        }
    }

    private string _instructionsText = string.Empty;
    private string InstructionsText
    {
        get => _instructionsText;
        set
        {
            _instructionsText = value;
            var list = value.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                            .Select(s => s.Trim())
                            .ToList();
            Recipe.InstructionsJson = JsonSerializer.Serialize(list);
        }
    }

    protected override void OnInitialized()
    {
        // Initialize text areas from JSON if editing
        if (!string.IsNullOrEmpty(Recipe.IngredientsJson) && Recipe.IngredientsJson != "[]")
        {
            try {
                var list = JsonSerializer.Deserialize<List<string>>(Recipe.IngredientsJson);
                if (list != null) _ingredientsText = string.Join("\n", list);
            } catch {}
        }

        if (!string.IsNullOrEmpty(Recipe.InstructionsJson) && Recipe.InstructionsJson != "[]")
        {
            try {
                var list = JsonSerializer.Deserialize<List<string>>(Recipe.InstructionsJson);
                if (list != null) _instructionsText = string.Join("\n", list);
            } catch {}
        }
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        ImageError = string.Empty;
        var file = e.File;
        if (file == null) return;

        try
        {
            var imageUrl = await RecipeService.UploadImageAsync(file);
            Recipe.ImageUrl = imageUrl;
        }
        catch (Exception ex)
        {
            ImageError = ex.Message;
        }
    }

    private async Task HandleSubmit()
    {
        if (IsSubmitting) return;

        IsSubmitting = true;
        try
        {
            await OnSubmit.InvokeAsync(Recipe);
        }
        finally
        {
            IsSubmitting = false;
        }
    }
}
